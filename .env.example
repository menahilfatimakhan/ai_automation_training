# ─── Supabase ─────────────────────────────────────────────────────────────
# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the browser. Used for seed/sync/admin tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (Drizzle migrations + server queries)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ─── Anthropic (advisory AI only) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-6   # optional override

# ─── Provider selection (ports & adapters) ────────────────────────────────
# Which ad provider implementation to inject. Mock reads committed fixtures.
AD_PROVIDER=mock          # mock | meta
FX_PROVIDER=live          # mock | live (live = free ECB/Frankfurter API, cached)
NOTIFIER=db               # db (in-app panel) | console
AI_PROVIDER=mock          # mock | anthropic (anthropic needs ANTHROPIC_API_KEY)
# FX_API_BASE=https://api.frankfurter.app   # optional override for the FX API

# ─── Ad-account token references (resolved by EnvSecretStore) ─────────────
# ad_connections.access_token_ref points at one of these env vars. With
# AD_PROVIDER=mock the value is unused (any non-empty string seeds fine).
META_TOKEN_ACME=mock-token
META_TOKEN_GLOBEX=mock-token
META_TOKEN_INITECH=mock-token

# ─── Meta (only needed when AD_PROVIDER=meta; see docs/INTEGRATIONS.md) ────
# META_GRAPH_API_VERSION=v21.0
